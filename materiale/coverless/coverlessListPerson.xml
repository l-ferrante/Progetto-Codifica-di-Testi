					<person xml:id="giovanniVerga">
						<persName type="real" role="author">
							<ref target="http://viaf.org/viaf/18647"/>
							<forename>Giovanni</forename>
							<surname>Verga</surname>
						</persName>
						<sex>M</sex>
						<birth>
							<date when="1840">1840</date>
							<placeName ref="TEI-ListPlace.xml#CT">Catania</placeName>
						</birth>
						<death>
							<date when="1922">1922</date>
							<placeName ref="TEI-ListPlace.xml#CT">Catania</placeName>
